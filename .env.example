# Supabase — project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. Needed for /admin email invites. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Used in invite redirect links (your Vercel URL in production)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only. Powers the AI Fitness Report (Claude vision). Without it, the
# Report tab shows a "not configured yet" notice instead of analyzing photos.
ANTHROPIC_API_KEY=your-anthropic-api-key
