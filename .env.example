# Supabase — project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. Needed for /admin email invites. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Used in invite redirect links (your Vercel URL in production)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional — when both are set, /admin invites also send a branded invite
# email via Resend (same key as your Supabase SMTP; sender must be on your
# verified Resend domain). Without them, invites show a copyable message.
RESEND_API_KEY=re_your-key
RESEND_FROM=sculpt@yourdomain.com
