<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Shared App Group so the widget can read the app's "next session"
	     snapshot. Add the SAME group to the main app target in Xcode. -->
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.com.sculpt.app</string>
	</array>
</dict>
</plist>
